class CameraThread(threading.Thread):
    """ camerathread runs single camera in its own thread. 
    allows continuous frame capture w/o blocking joystick input/motor control"""
    def __init__(self, cam_id, name, cap):
      """ initializes the camera thread
      cam_id is an integer representing the camera index
      name is a string representing the camera name
      cap is the cv2 VideoCapture object for the camera
      """
      super().__init__()
      self.cam_id= cam_id
      self.name= name
      self.cap= cap
      self.frame= None
      self.running= True
    def run(self):
       """main thread loop for camera frame capture.
       continuously captures frames from the camera and updates the latest frame 
       while running is true"""
       while self.running:
          ret, frame = self.cap.read()
          if ret:
             self.frame= frame #updates the latest frame
    def stop(self):
       self.running= False
       self.cap.release()
    
class CameraManager:
    def __init__(self):
       self.frames= {}
       self.caps= {
              "front": cv2.VideoCapture(0),
              "down": cv2.VideoCapture(1),
              "rear": cv2.VideoCapture(2),
              "left": cv2.VideoCapture(3),
              "right": cv2.VideoCapture(4),
       }
       self.running= True

       for name in self.caps:
          t= threading.Thread(target=self._update, args=(name,))
          t.daemon= True
          t.start()

    def _update(self, name):
       cap= self.caps[name]
       while self.running:
          ret, frame = cap.read()
          if ret:
             self.frames[name]= frame
    def get_frame(self, name):
       return self.frames.get(name)
    
